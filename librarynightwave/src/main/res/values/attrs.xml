<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="ZoomableTextureView">
        <attr name="minScale" format="float" />
        <attr name="maxScale" format="float" />
    </declare-styleable>

    <declare-styleable name="ZoomablePlayerView">
        <attr name="minimumScale" format="float" />
        <attr name="maximumScale" format="float" />
    </declare-styleable>

    <declare-styleable name="FullscreenAttrs">
        <attr name="fullscreenBackgroundColor" format="color" />
        <attr name="fullscreenTextColor" format="color" />
    </declare-styleable>
    <!-- loading bar attr-->
    <declare-styleable name="CircleLoadingIndicatorView">
        <attr name="minWidth" format="dimension" />
        <attr name="maxWidth" format="dimension"/>
        <attr name="minHeight" format="dimension" />
        <attr name="maxHeight" format="dimension"/>
        <attr name="indicatorName" format="string"/>
        <attr name="indicatorColor" format="color"/>
    </declare-styleable>


    <attr name="resize_mode" format="enum">
        <enum name="fit" value="0"/>
        <enum name="fixed_width" value="1"/>
        <enum name="fixed_height" value="2"/>
        <enum name="fill" value="3"/>
        <enum name="zoom" value="4"/>
    </attr>
    <declare-styleable name="AspectRatioFrameLayout">
        <attr name="resize_mode"/>
    </declare-styleable>

</resources>