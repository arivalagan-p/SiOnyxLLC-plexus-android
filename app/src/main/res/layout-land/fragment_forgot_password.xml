<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.sionyx.plexus.ui.login.ForgotPasswordViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/spash_screen_background_land"
        tools:context=".ui.login.ForgotPasswordFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            app:layout_constraintEnd_toStartOf="@+id/vertical_guideline_start_view"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/back_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="@{()->viewModel.onBackToLogin()}"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_baseline_arrow_back"
                tools:ignore="RtlSymmetry" />

            <TextView
                android:id="@+id/forgot_password_title_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/forgot_password"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/back_to_login"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tv_pwd_rules_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/password_must_8_text_status_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/password_must_8_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/password_must_8_text"
                    app:srcCompat="@drawable/ic_green_circle" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/password_must_8_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="4dp"
                    android:text="@string/password_must_have_at_least_8_characters"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toEndOf="@+id/password_must_8_text_status_icon"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="RtlSymmetry" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/password_include_special_character_text_status_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/password_include_special_character_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/password_must_8_text_status_icon"
                    app:layout_constraintTop_toTopOf="@+id/password_include_special_character_text"
                    app:srcCompat="@drawable/ic_green_circle" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/password_include_special_character_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="2"
                    android:paddingStart="4dp"
                    android:text="@string/password_must_include_at_least_one_special_character"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toEndOf="@+id/password_include_special_character_text_status_icon"
                    app:layout_constraintTop_toBottomOf="@+id/password_must_8_text"
                    tools:ignore="RtlSymmetry" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/password_include_upper_case_letter_text_status_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/password_include_upper_case_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/password_include_special_character_text_status_icon"
                    app:layout_constraintTop_toTopOf="@+id/password_include_upper_case_text"
                    app:srcCompat="@drawable/ic_green_circle" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/password_include_upper_case_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="4dp"
                    android:text="@string/password_must_include_at_least_one_uppercase_letter"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toEndOf="@+id/password_include_upper_case_letter_text_status_icon"
                    app:layout_constraintTop_toBottomOf="@+id/password_include_special_character_text"
                    tools:ignore="RtlSymmetry" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/password_include_lower_case_letter_text_status_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/password_include_lower_case_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/password_include_upper_case_letter_text_status_icon"
                    app:layout_constraintTop_toTopOf="@+id/password_include_lower_case_text"
                    app:srcCompat="@drawable/ic_green_circle" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/password_include_lower_case_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="4dp"
                    android:text="@string/password_must_include_at_least_one_lowercase_letter"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toEndOf="@+id/password_include_lower_case_letter_text_status_icon"
                    app:layout_constraintTop_toBottomOf="@+id/password_include_upper_case_text"
                    tools:ignore="RtlSymmetry" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/password_include_number_text_status_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/password_include_number_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/password_include_lower_case_letter_text_status_icon"
                    app:layout_constraintTop_toTopOf="@+id/password_include_number_text"
                    app:srcCompat="@drawable/ic_green_circle" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/password_include_number_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="4dp"
                    android:text="@string/password_must_include_at_least_one_number"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toEndOf="@+id/password_include_number_text_status_icon"
                    app:layout_constraintTop_toBottomOf="@+id/password_include_lower_case_text"
                    tools:ignore="RtlSymmetry" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/user_description_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible"
                app:layout_constraintBottom_toTopOf="@+id/re_sent_otp_duration_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/forgot_password_title_text">

                <ScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/user_description_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:paddingStart="4dp"
                        android:text="@string/forgot_password_empty_content_msg"
                        android:textColor="@color/white"
                        app:layout_constraintBottom_toTopOf="@+id/re_sent_otp_duration_text"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/forgot_password_title_text"
                        tools:ignore="RtlSymmetry" />
                </ScrollView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/re_sent_otp_duration_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="@+id/vertical_guideline_start_view"
            app:layout_constraintTop_toTopOf="parent">

            <ScrollView
                android:id="@+id/scroll_view_top"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/password"
                android:scrollbars="none"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/password_root_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/vertical_guideline_start_view"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/password_reset_user_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="@string/your_password_reset_has_already_been_initiated_please_set_a_new_password_to_log_in_again"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:layout_margin="8dp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/sent_otp_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@+id/password_reset_user_message">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/Username_edit_text_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="16dp"
                            app:boxBackgroundColor="@color/color_grey"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:startIconDrawable="@drawable/ic_user"
                            app:startIconTint="@color/black">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/Username_edit_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/username"
                                android:imeOptions="actionDone"
                                android:importantForAutofill="no"
                                android:maxLines="1"
                                android:inputType="text"
                                android:paddingStart="48dp"
                                android:singleLine="true"
                                android:textColor="@color/white"
                                android:textColorHint="@color/light_white"
                                tools:ignore="RtlSymmetry" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/sent_confirm_code"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="32dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/button_corner_radius_white"
                            android:gravity="center"
                            android:onClick="@{()->viewModel.onSentOTPCode()}"
                            android:text="@string/sent_otp"
                            android:textAllCaps="false"
                            android:textColor="@color/black"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/Username_edit_text_layout" />

                        <TextView
                            android:id="@+id/response_message_textview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="16dp"
                            android:maxLines="2"
                            android:textAlignment="viewStart"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="@dimen/large_sp"
                            android:visibility="gone"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/Username_edit_text_layout" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- change new password layout-->

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/change_password_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/sent_otp_layout">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/change_password_view_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/confirm_code_edit_text_layout"
                                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="16dp"
                                android:hint="@string/enter_otp"
                                android:textColorHint="@color/light_gray"
                                app:boxBackgroundColor="@color/color_grey"
                                app:boxCornerRadiusBottomStart="4dp"
                                app:boxCornerRadiusTopEnd="4dp"
                                app:boxStrokeColor="@color/white"
                                app:hintTextColor="@color/light_white"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/confirm_code_edit_text"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:imeOptions="actionNext"
                                    android:importantForAutofill="no"
                                    android:inputType="number"
                                    android:maxLines="1"
                                    android:singleLine="true"
                                    android:textColorHint="@color/light_white"
                                    android:textColor="@color/white" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/new_pwd_edit_text_layout"
                                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="16dp"
                                android:hint="@string/new_password"
                                android:textColorHint="@color/light_gray"
                                app:hintTextColor="@color/light_white"
                                app:boxBackgroundColor="@color/color_grey"
                                app:boxCornerRadiusBottomStart="4dp"
                                app:boxCornerRadiusTopEnd="4dp"
                                app:boxStrokeColor="@color/white"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/confirm_code_edit_text_layout"
                                app:startIconDrawable="@drawable/ic_key_icon"
                                app:startIconTint="@color/black">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/new_pwd_edit_text"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:imeOptions="actionNext"
                                    android:importantForAutofill="no"
                                    android:inputType="textPassword"
                                    android:maxLines="1"
                                    android:paddingStart="48dp"
                                    android:singleLine="true"
                                    android:textColor="@color/white"
                                    android:textColorHint="@color/light_white"
                                    tools:ignore="RtlSymmetry" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/confirm_new_pwd_edit_text_layout"
                                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="16dp"
                                android:hint="@string/confirm_password"
                                android:textColorHint="@color/light_gray"
                                app:boxBackgroundColor="@color/color_grey"
                                app:boxCornerRadiusBottomStart="4dp"
                                app:boxCornerRadiusTopEnd="4dp"
                                app:boxStrokeColor="@color/white"
                                app:endIconTint="@color/color_grey"
                                app:hintTextColor="@color/light_white"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/new_pwd_edit_text_layout"
                                app:startIconDrawable="@drawable/ic_key_icon"
                                app:startIconTint="@color/black">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/confirm_new_pwd_edit_text"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:imeOptions="actionDone"
                                    android:importantForAutofill="no"
                                    android:inputType="textPassword"
                                    android:maxLines="1"
                                    android:paddingStart="48dp"
                                    android:singleLine="true"
                                    android:textColor="@color/white"
                                    android:textColorHint="@color/light_white"
                                    tools:ignore="RtlSymmetry" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <androidx.appcompat.widget.AppCompatCheckBox
                                android:id="@+id/show_password"
                                android:layout_width="wrap_content"
                                android:layout_height="48dp"
                                android:layout_margin="12dp"
                                android:buttonTint="@color/white"
                                android:padding="0dp"
                                android:text="@string/show_password"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/confirm_new_pwd_edit_text_layout" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/new_pwd_submit_btn"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="16dp"
                                android:background="@drawable/button_corner_radius_white"
                                android:gravity="center"
                                android:onClick="@{()->viewModel.onSubmitChangePassword()}"
                                android:text="@string/reset_password"
                                android:textAllCaps="false"
                                android:textColor="@color/black"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/show_password" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="8dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/new_pwd_submit_btn" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>


            </ScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!--
                <ScrollView
                    android:id="@+id/scroll_view_top"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/password"
