<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp">

        <ScrollView
            android:layout_width="match_parent"
            style="@style/scrollbar_style"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/info_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/patent_info"

                    android:textAllCaps="true"
                    android:textSize="@dimen/text_size"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/info_data"
                    android:layout_width="0dp"
                    android:textColor="@color/white"
                    android:layout_marginEnd="12dp"

                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    android:gravity="end"
                    android:text="@string/sionyx_com_patents"
                    android:textSize="@dimen/text_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/copy_right"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/copyright"

                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size"
                    android:layout_marginTop="16dp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/info_name" />

                <TextView
                    android:id="@+id/copy_right_data"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="end"
                    android:textColor="@color/white"
                    android:layout_marginEnd="12dp"
                    android:text="@string/copyright_value"
                    app:layout_constraintStart_toEndOf="@+id/guideline"

                    android:textSize="@dimen/text_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/info_data" />

                <TextView
                    android:id="@+id/language"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/language"

                    android:textAllCaps="true"
                    android:textSize="@dimen/text_size"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/copy_right" />

                <TextView
                    android:id="@+id/language_data"
                    android:layout_width="0dp"
                    android:textColor="@color/white"
                    android:layout_marginEnd="12dp"

                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    android:gravity="end"
                    android:text="@string/english"
                    android:layout_marginTop="16dp"
                    android:textSize="@dimen/text_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/copy_right_data" />


                <TextView
                    android:id="@+id/app_version"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/app_version"

                    android:textAllCaps="true"
                    android:textSize="@dimen/text_size"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/language" />

                <TextView
                    android:id="@+id/app_version_data"
                    android:layout_width="0dp"
                    android:textColor="@color/white"
                    android:layout_marginEnd="12dp"

                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    android:gravity="end"
                    android:layout_marginTop="16dp"
                    android:text="@string/app_version_number"
                    android:textSize="@dimen/text_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/language_data" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>