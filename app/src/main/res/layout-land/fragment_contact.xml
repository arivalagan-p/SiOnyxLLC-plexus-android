<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ContactFragment">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/dot_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/ic_contact_dot"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/contact"
            android:textColor="@color/white"
            android:layout_width="0dp"

            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@+id/dot_icon"
            android:text="@string/support_sionyx_com"
            android:textSize="@dimen/text_size"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/dot_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/dot_icon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/dot_icon1"
            android:layout_width="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/ic_contact_dot"
            app:layout_constraintTop_toBottomOf="@+id/dot_icon" />

        <TextView
            android:textColor="@color/white"
            android:layout_width="0dp"

            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@+id/dot_icon1"
            android:text="@string/contact_no"
            android:textSize="@dimen/text_size"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/dot_icon1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/dot_icon1" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>