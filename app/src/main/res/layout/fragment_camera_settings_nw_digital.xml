<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/llWebview"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_setting_outer_layout_background_with_border">
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="1dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="5dp">
    <WebView
        android:id="@+id/nw_digital_web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>
    <TextView
        android:visibility="gone"
        android:id="@+id/tvWebViewNotReachable"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="@string/webview_not_reachable"/>
</androidx.constraintlayout.widget.ConstraintLayout>
