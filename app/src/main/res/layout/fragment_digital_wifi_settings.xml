<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.sionyx.plexus.ui.cameramenu.model.CameraPasswordSettingViewModel" />

        <variable
            name="cameraName"
            type="String" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cardview_dark_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/settingTitleStartGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.038" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/settingTitleTopGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.064" />

        <!--    title-->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/wifi_setting_title"
            android:layout_width="160dp"
            android:layout_height="50dp"
            android:gravity="center|start"
            android:text="@string/digital_wifi_settings"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:layout_constraintStart_toStartOf="@+id/settingTitleStartGuideline"
            app:layout_constraintTop_toTopOf="@+id/settingTitleTopGuideline" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/wifi_setting_close_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:onClick="@{()->viewModel.onSelectCancel()}"
            android:clickable="true"
            android:src="@drawable/ic_cancel_icon"
            app:layout_constraintEnd_toEndOf="@+id/endGuideline"
            app:layout_constraintTop_toTopOf="@+id/settingTitleTopGuideline" />

        <View
            android:id="@+id/view_line1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginBottom="8dp"
            android:background="@color/colordarkgrey"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/wifi_setting_title" />

        <!--    change password-->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/wifi_settings_camera_connected_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/view_line1">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/textViewStartGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.038" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/wifi_change_pwd_text"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:gravity="center|start"
                android:onClick="@{()->viewModel.onSelectChangePassword()}"
                android:text="@string/change_password"
                android:textAllCaps="true"
                android:textColor="@color/white"
                app:layout_constraintEnd_toStartOf="@+id/pwdStartGuideline"
                app:layout_constraintStart_toStartOf="@+id/textViewStartGuideline"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/wifi_change_pwd_arrow_ok"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_right"
                android:onClick="@{()->viewModel.onSelectChangePassword()}"
                android:layout_marginTop="25dp"
                android:layout_margin="10dp"
                app:layout_constraintEnd_toEndOf="@+id/endViewGuideline"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/view_line2"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginBottom="8dp"
                android:background="@color/colordarkgrey"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/wifi_change_pwd_text" />


            <!--    activate/deactivate-->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/wifi_activate_connection_text"
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:gravity="center|start"
                android:text="@string/activate_connection"
                android:textAllCaps="true"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="@+id/textViewStartGuideline"
                app:layout_constraintTop_toBottomOf="@id/view_line2" />

            <FrameLayout
                android:id="@+id/autoConnectSwitch"
                android:layout_width="46dp"
                android:layout_height="29dp"
                android:background="@drawable/bg_switch_off"
                android:padding="3dp"
                android:layout_marginTop="15dp"
                app:layout_constraintTop_toBottomOf="@+id/view_line2"
                app:layout_constraintEnd_toEndOf="@id/endViewGuideline">

                <View
                    android:id="@+id/autoConnectKnob"
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:padding="5dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@drawable/bg_knob" />
            </FrameLayout>

            <View
                android:id="@+id/view_line3"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginBottom="8dp"
                android:background="@color/colordarkgrey"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/wifi_activate_connection_text" />

            <!--    show password-->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/wifi_show_pwd_text"
                android:layout_width="160dp"
                android:layout_height="55dp"
                android:gravity="center|start"
                android:text="@string/show_password"
                android:textAllCaps="true"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="@+id/textViewStartGuideline"
                app:layout_constraintTop_toBottomOf="@id/view_line3" />

            <FrameLayout
                android:id="@+id/showPasswordSwitch"
                android:layout_width="46dp"
                android:layout_height="29dp"
                android:background="@drawable/bg_switch_off"
                android:padding="3dp"
                android:layout_marginTop="15dp"
                app:layout_constraintTop_toBottomOf="@+id/view_line3"
                app:layout_constraintEnd_toEndOf="@id/endViewGuideline">

                <View
                    android:id="@+id/showPasswordKnob"
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:padding="5dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@drawable/bg_knob" />
            </FrameLayout>

            <View
                android:id="@+id/view_line4"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginBottom="8dp"
                android:background="@color/colordarkgrey"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/wifi_show_pwd_text" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/pwdTopGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.089" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/androidAutoTopGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.163" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/showPwdTopGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.239" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/pwdStartGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.839" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/endViewGuideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.93" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/wifi_setting_camera_name_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center_horizontal"
            android:text="NWD_"
            android:textAllCaps="true"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


        <WebView
            android:id="@+id/wifi_setting_show_info_webview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/cardview_dark_background"
            android:textColor="@color/white"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/view_line1" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/endGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.92" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>