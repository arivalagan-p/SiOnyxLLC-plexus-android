<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="viewModel"
            type="com.sionyx.plexus.ui.camera.menus.CameraTabLayoutViewModel" />

        <variable
            name="cameraName"
            type="String" />
        <variable
            name="isLoading"
            type="boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/camera_settings_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/camera_icon_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:gravity="end"
                android:text="@{cameraName}"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size"
                app:layout_constraintBottom_toTopOf="@+id/camera_name_horizontal_guideline_bottom"
                app:layout_constraintEnd_toStartOf="@+id/camera_model_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/camera_name_horizontal_guideline_top" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/camera_model_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_opsin_345_discover"
                app:layout_constraintBottom_toTopOf="@+id/camera_icon_horizontal_guideline_bottom"
                app:layout_constraintEnd_toStartOf="@+id/tab_view_vertical_guideline_end"
                app:layout_constraintTop_toBottomOf="@+id/camera_icon_horizontal_guideline_top" />
            <!--  NWD camera web setting UI-->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
            <include
                android:id="@+id/camera_setting_nw_digital_layout"
                android:visibility="visible"
                android:layout_width="0dp"
                android:layout_height="0dp"
                layout="@layout/fragment_camera_settings_nw_digital"
                app:layout_constraintEnd_toEndOf="@+id/web_view_vertical_guideline_end"
                app:layout_constraintStart_toStartOf="@+id/web_view_vertical_guideline_start"
                app:layout_constraintTop_toTopOf="@id/web_view_layout_vertical_guideline_top"
                app:layout_constraintBottom_toBottomOf="@id/web_view_vertical_guideline_bottom"/>
                <com.sionyx.plexus.utils.circulardotprogressbar.CircleLoadingIndicatorView
                    android:id="@+id/custom_progress_bar"
                    style="@style/CircleLoadingIndicatorView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:indicatorColor="@color/black"
                    app:indicatorName="DotCircleProgressIndicator"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.640"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.599" />
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/web_camera_settings_cancel_icon"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="@{() -> viewModel.onCancel()}"
                android:src="@drawable/ic_cancel_icon"
                app:layout_constraintEnd_toEndOf="@+id/web_cancel_icon_vertical_guideline_end"
                app:layout_constraintStart_toStartOf="@+id/web_cancel_icon_vertical_guideline_start"
                app:layout_constraintTop_toTopOf="@+id/web_cancel_icon_horizontal_guideline_top"
                app:layout_constraintBottom_toBottomOf="@+id/web_cancel_icon_horizontal_guideline_bottom"/>

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_view_vertical_guideline_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.2742" />
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_view_vertical_guideline_end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.9794" />
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_cancel_icon_vertical_guideline_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.9310" />
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_cancel_icon_vertical_guideline_end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.9617" />
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_cancel_icon_horizontal_guideline_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.2818" />
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_cancel_icon_horizontal_guideline_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.3540" />
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_view_vertical_guideline_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.9267" />
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/web_view_layout_vertical_guideline_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.2469" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/camera_settings_layout_container"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/ic_tab_layout_background"
                app:layout_constraintBottom_toBottomOf="@+id/tab_view_horizontal_guideline_bottom"
                app:layout_constraintEnd_toEndOf="@+id/tab_view_vertical_guideline_end"
                app:layout_constraintStart_toStartOf="@+id/tab_view_vertical_guideline_start"
                app:layout_constraintTop_toTopOf="@+id/tab_view_horizontal_guideline_top">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tabLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        app:layout_constraintTop_toTopOf="@+id/tab_layout_vertical_guideline_top"
                        app:layout_constraintEnd_toEndOf="@+id/tab_layout_view_vertical_guideline_end"
                        app:layout_constraintStart_toStartOf="@+id/tab_layout_view_vertical_guideline_start"
                        app:tabBackground="@drawable/ic_tab_rectangle"
                        app:tabIndicatorColor="@color/color_lightgrey"
                        app:tabIndicatorGravity="bottom"
                        app:tabMode="fixed"
                        app:tabMaxWidth="0dp"
                        app:tabTextColor="@color/white" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/camera_settings_cancel_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> viewModel.onCancel()}"
                        android:src="@drawable/ic_cancel_icon"
                        app:layout_constraintEnd_toEndOf="@+id/cancel_icon_vertical_guideline_end"
                        app:layout_constraintStart_toStartOf="@+id/cancel_icon_vertical_guideline_start"
                        app:layout_constraintTop_toTopOf="@+id/cancel_icon_horizontal_guideline_top"
                        app:layout_constraintBottom_toBottomOf="@+id/cancel_icon_horizontal_guideline_bottom"/>

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/viewPager"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginTop="26dp"
                        android:layout_marginBottom="8dp"
                        app:layout_behavior="@string/appbar_scrolling_view_behavior"
                        app:layout_constraintBottom_toTopOf="@id/preser_save_layout"
                        app:layout_constraintEnd_toEndOf="@id/viewpager_vertical_guideline_end"
                        app:layout_constraintStart_toStartOf="@+id/tab_layout_view_vertical_guideline_start"
                        app:layout_constraintTop_toBottomOf="@id/tabLayout" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/preser_save_layout"
                        android:layout_width="0dp"
                        android:visibility="gone"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="@+id/viewpager_vertical_guideline_end"
                        app:layout_constraintStart_toStartOf="@+id/tab_layout_view_vertical_guideline_start">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:id="@+id/viewline"
                            android:layout_marginBottom="4dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:background="@color/white"
                            app:layout_constraintBottom_toTopOf="@+id/save_settings"/>

                        <TextView
                            android:id="@+id/save_settings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/black"
                            android:background="@drawable/button_solid_white"
                            android:gravity="center"
                            android:onClick="@{() -> viewModel.onSaveSettings()}"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:text="@string/save"/>

                        <TextView
                            android:id="@+id/back_save_settings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"
                            android:onClick="@{() -> viewModel.onCancel()}"
                            android:background="@drawable/button_stroke"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/save_settings"
                            android:text="@string/back"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/tab_layout_vertical_guideline_top"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintGuide_percent="0.0309" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/tab_layout_vertical_guideline_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintGuide_percent="0.1786" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/tab_layout_view_vertical_guideline_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.6477" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/tab_layout_view_vertical_guideline_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent=" 0.0321" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/viewpager_vertical_guideline_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.1041" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/viewpager_vertical_guideline_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.9724" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/view_pager_horizontal_guideline_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintGuide_percent="0.9381" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/cancel_icon_vertical_guideline_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.9310" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/cancel_icon_vertical_guideline_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.9617" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/cancel_icon_horizontal_guideline_top"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintGuide_percent="0.0618" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/cancel_icon_horizontal_guideline_bottom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintGuide_percent="0.1340" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/tab_view_vertical_guideline_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.2742" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/tab_view_vertical_guideline_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.9794" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/tab_view_horizontal_guideline_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.25" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/tab_view_horizontal_guideline_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.9299" />


            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/camera_icon_horizontal_guideline_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.0700" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/camera_icon_horizontal_guideline_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent=" 0.2102" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/camera_name_horizontal_guideline_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.1238" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/camera_name_horizontal_guideline_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.1612" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>