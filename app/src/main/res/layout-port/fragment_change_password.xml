<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.sionyx.plexus.ui.cameramenu.model.CameraPasswordSettingViewModel" />

        <variable
            name="cameraName"
            type="String" />
        <variable
            name="isLoading"
            type="Boolean" />
    </data>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/black">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout2"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/arrowTopGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.19" />
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/arrowBottomGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.889" />
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/arrowStartGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.020" />
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/arrowEndGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.11" />
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/change_pwd_back"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/left_arrow"
            android:onClick="@{()->viewModel.onSelectBack()}"
            app:layout_constraintStart_toEndOf="@id/arrowStartGuideline"
            app:layout_constraintTop_toBottomOf="@id/arrowTopGuideline"
            app:layout_constraintBottom_toTopOf="@id/arrowBottomGuideline"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center_vertical"
            android:text="@string/change_password"
            android:textSize="18sp"
            android:textAlignment="center"
            android:textAllCaps="true"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/change_pwd_back"
            app:layout_constraintTop_toBottomOf="@id/arrowTopGuideline"
            app:layout_constraintBottom_toTopOf="@id/arrowBottomGuideline"
            tools:ignore="RtlCompat" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/change"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/constraintLayout2"
        app:layout_constraintVertical_bias="1.0">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/pwdStartGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="20dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/pwdEndGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="20dp" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/edit_old_pwd_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_nightwave_outlined_box"
            android:padding="10dp"
            android:hint="@string/old_password"
            android:inputType="textPassword"
            android:focusable="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:textColor="@color/white"
            android:textColorHint="@color/colordarkgrey"
            android:drawableStart="@drawable/ic_key_icon"
            android:drawablePadding="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/pwdStartGuideline"
            app:layout_constraintEnd_toStartOf="@id/pwdEndGuideline"
            android:layout_marginTop="56dp"/>

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/edit_new_pwd_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_nightwave_outlined_box"
            android:hint="@string/new_password"
            android:inputType="textPassword"
            android:textColor="@color/white"
            android:textColorHint="@color/colordarkgrey"
            android:drawableStart="@drawable/ic_key_icon"
            android:drawablePadding="15dp"
            android:padding="10dp"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toEndOf="@id/pwdStartGuideline"
            app:layout_constraintEnd_toStartOf="@id/pwdEndGuideline"
            app:layout_constraintTop_toBottomOf="@+id/edit_old_pwd_text"/>
        <include
            android:id="@+id/newPwdRules"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="visible"
            layout="@layout/regex_layout"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/pwdStartGuideline"
            app:layout_constraintEnd_toStartOf="@id/pwdEndGuideline"
            app:layout_constraintTop_toBottomOf="@+id/edit_new_pwd_text" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/edit_confirm_pwd_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_nightwave_outlined_box"
            android:hint="@string/confirm_password"
            android:inputType="textPassword"
            android:textColor="@color/white"
            android:textColorHint="@color/colordarkgrey"
            android:drawableStart="@drawable/ic_key_icon"
            android:drawablePadding="15dp"
            android:padding="10dp"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toEndOf="@id/pwdStartGuideline"
            app:layout_constraintEnd_toStartOf="@id/pwdEndGuideline"
            app:layout_constraintTop_toBottomOf="@+id/newPwdRules" />

        <include
            android:id="@+id/confirmPwdRules"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="visible"
            layout="@layout/regex_layout"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/pwdStartGuideline"
            app:layout_constraintEnd_toStartOf="@id/pwdEndGuideline"
            app:layout_constraintTop_toBottomOf="@+id/edit_confirm_pwd_text" />

        <androidx.appcompat.widget.AppCompatCheckBox
            android:id="@+id/show_password"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:buttonTint="@color/white"
            android:padding="0dp"
            android:text="@string/show_password"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:layout_constraintStart_toEndOf="@id/pwdStartGuideline"
            app:layout_constraintTop_toBottomOf="@+id/confirmPwdRules" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/changePwdButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="10dp"
            android:background="@drawable/button_corner_radius_white"
            android:gravity="center"
            android:text="@string/change_password"
            android:onClick="@{()->viewModel.onChangePasswordButton()}"
            android:textAllCaps="false"
            android:textColor="@color/black"
            app:layout_constraintStart_toEndOf="@id/pwdStartGuideline"
            app:layout_constraintEnd_toStartOf="@id/pwdEndGuideline"
            app:layout_constraintTop_toBottomOf="@+id/show_password" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/cameraNameStartGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="35dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/cameraNameEndGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="35dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/cameraNameTopGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.90"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/cameraNameBottomGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.95"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/camera_name"
            android:layout_width="0dp"
            android:layout_height="19dp"
            android:gravity="center"
            android:text="NWD_"
            android:textColor="@color/white"
            app:layout_constraintBottom_toTopOf="@id/cameraNameBottomGuideline"
            app:layout_constraintTop_toBottomOf="@id/cameraNameTopGuideline"
            app:layout_constraintStart_toEndOf="@id/cameraNameStartGuideline"
            app:layout_constraintEnd_toStartOf="@id/cameraNameEndGuideline" />

        <com.sionyx.plexus.utils.circulardotprogressbar.CircleLoadingIndicatorView
            android:id="@+id/custom_progress_bar"
            style="@style/CircleLoadingIndicatorView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorColor="@color/light_white"
            android:visibility="gone"
            app:indicatorName="DotCircleProgressIndicator"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.499"
            app:showIf="@{isLoading}" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
</layout>